<odoo>
    <data>
        <record id="view_portfolio_tree" model="ir.ui.view">
            <field name="name">view_portfolio_tree</field>
            <field name="model">investing.portfolio</field>
            <field name="arch" type="xml">
                <list decoration-success="profit_loss > 0" decoration-danger="profit_loss &lt; 0">
                    <field name="company_id"/>
                    <field name="shares"/>
                    <field name="purchase_price"/>
                    <field name="current_value"/>
                    <field name="profit_loss"/>
                    <field name="roi"/>
                </list>
            </field>
        </record>
        <record id="view_portfolio_form" model="ir.ui.view">
            <field name="name">view_portfolio_form</field>
            <field name="model">investing.portfolio</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group string="Position">
                            <field name="company_id"/>
                            <field name="shares"/>
                            <field name="purchase_price"/>
                        </group>
                        <group string="Performance">
                            <field name="current_value"/>
                            <field name="profit_loss"/>
                            <field name="roi"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_investing_portfolio" model="ir.actions.act_window">
            <field name="name">Portfolio</field>
            <field name="res_model">investing.portfolio</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
