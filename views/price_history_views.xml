<odoo>
    <data>
        <record id="price_history_tree" model="ir.ui.view">
            <field name="name">view_history_price_tree</field> 
            <field name="model">investing.price.history</field>
            <field name="arch" type="xml">
                <list create="false">
                    <field name="company_id"/>
                    <field name="date"/>
                    <field name="close_price"/>
                    <field name="volume"/>
                </list>
            </field>
        </record>
        <record id="price_history_form" model="ir.ui.view">
            <field name="name">view_history_price_form</field>
            <field name="model">investing.price.history</field>
            <field name="arch" type="xml">
                <form create="false">
                    <sheet>
                        <group name="history price">
                            <field name="company_id"/>
                            <field name="date"/>
                            <field name="close_price"/>
                            <field name="volume"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_investing_price_history" model="ir.actions.act_window">
            <field name="name">Price History</field>
            <field name="res_model">investing.price.history</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'group_by': 'company_id'}</field>
        </record> 
    </data>
</odoo>