<odoo>
    <data>
        <record id="view_investing_company_tree" model="ir.ui.view">
            <field name="name">investing.company.tree</field>
            <field name="model">investing.company</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="ticker"/>
                    <field name="sector"/>
                    <field name="current_price"/>
                    <field name="last_update"/>
                </list>
            </field>
        </record>
        <record id="view_investing_company_form" model="ir.ui.view">
            <field name="name">investing.company.form</field>
            <field name="model">investing.company</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_sync_data" type="object" string="Sync Data" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group string="Company Info">
                            <field name="name"/>
                            <field name="ticker"/>
                            <field name="sector"/>
                            <field name="currency"/>
                        </group>
                        <group string="Market Data">
                            <field name="current_price"/>
                            <field name="last_update"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_server_sync_all" model="ir.actions.server">
            <field name="name">Sync All Companies</field>
            <field name="model_id" ref="model_investing_company"/>
            <field name="binding_model_id" ref="model_investing_company"/>
            <field name="binding_type">action</field>
            <field name="state">code</field>
            <field name="code">model.action_sync_all_companies()</field>
        </record>
        <record id="action_investing_company" model="ir.actions.act_window">
            <field name="name">Companies</field>
            <field name="res_model">investing.company</field>
            <field name="view_mode">list,form</field>
        </record>     
    </data>   
</odoo>

