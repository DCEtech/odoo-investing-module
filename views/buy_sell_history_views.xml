<odoo>
    <data>
        <record id="buy_sell_history_tree" model="ir.ui.view">
            <field name="name">view_buy_sell_history_tree</field>
            <field name="model">investing.buy.sell.history</field>
            <field name="arch" type="xml">
                <list create="false" edit="false" decoration-info="order_type == 'buy'" decoration-warning="order_type == 'sell'">
                    <field name="company_id"/>
                    <field name="date"/>
                    <field name="order_type"/>
                    <field name="shares"/>
                    <field name="price"/>
                    <field name="remaining_shares"/>
                    <field name="realized_profit"/>
                </list>
            </field>
        </record>
        <record id="buy_sell_history_form" model="ir.ui.view">
            <field name="name">view_buy_sell_history_form</field>
            <field name="model">investing.buy.sell.history</field>
            <field name="arch" type="xml">
                <form create="false" edit="false">
                    <sheet>
                        <group name="buy_sell_history">
                            <field name="company_id"/>
                            <field name="date"/>
                            <field name="order_type"/>
                            <field name="shares"/>
                            <field name="price"/>
                            <field name="remaining_shares"/>
                            <field name="realized_profit"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="buy_sell_history_search" model="ir.ui.view">
            <field name="name">view_buy_sell_history_search</field>
            <field name="model">investing.buy.sell.history</field>
            <field name="arch" type="xml">
                <search>
                    <field name="company_id"/>
                    <field name="order_type"/>
                    <filter string="Buy" name="filter_buy" domain="[('order_type', '=', 'buy')]"/>
                    <filter string="Sell" name="filter_sell" domain="[('order_type', '=', 'sell')]"/>
                    <group>
                        <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}"/>
                        <filter string="Year" name="group_by_year" context="{'group_by': 'date:year'}"/>
                    </group>
                </search>
            </field>
        </record>
        <record id="action_investing_buy_sell_history" model="ir.actions.act_window">
            <field name="name">Buy/Sell History</field>
            <field name="res_model">investing.buy.sell.history</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'group_by': 'company_id'}</field>
        </record>
    </data>
</odoo>
